# BrainRAY Continuation v6.5 delta
# Base: v6.4 No Progress Protection + Thesis Failure Exit
# New: Dynamic Breakeven for TEST replay/observation

BRAIN_NAME="BrainRAY_Continuation_v6.5_modular_TEST"

# Keep replay safe for TEST replay only
ENABLE_HTTP_FORWARD="false"
REPLAY_ALLOW_STALE_DATA="true"
REPLAY_USE_EVENT_TIME_FOR_POSITION_CLOCK="true"
FORWARD_EXIT_WHEN_FLAT="false"

# Keep current risk baseline
HARD_STOP_PCT="1.0"
BREAKEVEN_ARM_PCT="0.40"
BREAKEVEN_OFFSET_PCT="0.05"
FIRST_ENTRY_FAIL_FAST_ENABLED="false"
FIRST_ENTRY_FAIL_FAST_BARS="12"
FIRST_ENTRY_CONFIRM_MIN_ADX="13.5"

# v6.4: No Progress Protection
FIRST_ENTRY_NO_PROGRESS_ENABLED="true"
FIRST_ENTRY_NO_PROGRESS_MIN_BARS="6"
FIRST_ENTRY_NO_PROGRESS_MAX_BARS="10"
FIRST_ENTRY_NO_PROGRESS_MIN_PEAK_PCT="0.25"
FIRST_ENTRY_NO_PROGRESS_MAX_CURRENT_PCT="0.10"
FIRST_ENTRY_NO_PROGRESS_EXIT_IF_CLOSE_BELOW_EMA8="true"
FIRST_ENTRY_NO_PROGRESS_EXIT_IF_CLOSE_BELOW_EMA18="false"
FIRST_ENTRY_NO_PROGRESS_RSI_BELOW="52"
FIRST_ENTRY_NO_PROGRESS_REQUIRE_NOT_BULLISH_FVVO="true"
FIRST_ENTRY_NO_PROGRESS_REQUIRE_ENTRY_MODE_FIRST="true"
FIRST_ENTRY_NO_PROGRESS_LOG="true"

# v6.4: Thesis Failure Exit
FIRST_ENTRY_THESIS_FAIL_ENABLED="true"
FIRST_ENTRY_THESIS_FAIL_MIN_BARS="4"
FIRST_ENTRY_THESIS_FAIL_MAX_BARS="18"
FIRST_ENTRY_THESIS_FAIL_MIN_LOSS_PCT="-0.25"
FIRST_ENTRY_THESIS_FAIL_MAX_PEAK_PCT="0.10"
FIRST_ENTRY_THESIS_FAIL_RSI_BELOW="50"
FIRST_ENTRY_THESIS_FAIL_REQUIRE_CLOSE_BELOW_EMA18="true"
FIRST_ENTRY_THESIS_FAIL_REQUIRE_CLOSE_BELOW_EMA8="false"
FIRST_ENTRY_THESIS_FAIL_REQUIRE_NOT_BULLISH_FVVO="true"
FIRST_ENTRY_THESIS_FAIL_REQUIRE_ENTRY_MODE_FIRST="true"
FIRST_ENTRY_THESIS_FAIL_LOG="true"

# v6.5: Dynamic Breakeven
# weak/choppy -> protect earlier; normal -> v6.4 baseline; strong trend -> give more room
DYNAMIC_BREAKEVEN_ENABLED="true"
DYNAMIC_BE_WEAK_ARM_PCT="0.30"
DYNAMIC_BE_NORMAL_ARM_PCT="0.40"
DYNAMIC_BE_STRONG_ARM_PCT="0.50"
DYNAMIC_BE_WEAK_OFFSET_PCT="0.03"
DYNAMIC_BE_NORMAL_OFFSET_PCT="0.05"
DYNAMIC_BE_STRONG_OFFSET_PCT="0.05"
DYNAMIC_BE_WEAK_MAX_RSI="54"
DYNAMIC_BE_WEAK_MAX_ADX="18"
DYNAMIC_BE_WEAK_IF_CLOSE_BELOW_EMA8="true"
DYNAMIC_BE_WEAK_IF_BEARISH_FVVO="true"
DYNAMIC_BE_STRONG_MIN_RSI="64"
DYNAMIC_BE_STRONG_MIN_ADX="30"
DYNAMIC_BE_STRONG_REQUIRE_EMA8_ABOVE_EMA18="true"
DYNAMIC_BE_STRONG_REQUIRE_CLOSE_ABOVE_EMA8="true"
DYNAMIC_BE_STRONG_BLOCK_IF_BEARISH_FVVO="true"
DYNAMIC_BE_LOG="true"

# For LIVE after replay/demo validation, change only these execution variables:
# BRAIN_NAME="BrainRAY_Continuation_v6.5_modular_LIVE"
# ENABLE_HTTP_FORWARD="true"
# REPLAY_ALLOW_STALE_DATA="false"
# REPLAY_USE_EVENT_TIME_FOR_POSITION_CLOCK="false"
